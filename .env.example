# Required environment variables for deployment (Railway / Streamlit Cloud)
# Copy to .env for local development

# Google Cloud service account JSON (paste the full JSON string)
GCP_SERVICE_ACCOUNT_JSON=

# Google Drive folder ID containing brand sheets
DRIVE_FOLDER_ID=

# Config sheet ID (_DataCenterConfig)
CONFIG_SHEET_ID=

# Admin password — required, admin login is disabled without this
ADMIN_PASSWORD=
